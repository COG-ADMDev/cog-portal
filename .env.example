# cog-portal — environment variables template
# Copy this to .env.local and fill in. Never commit .env.local.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (Phase 4B — values added when auth is wired)
# JWT_SECRET=
# RESEND_API_KEY=
# OTP_TTL_MINUTES=10

# Datastore (Phase 4C — values added when DB is provisioned)
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Vault sync (Phase 4E — values added when sync engine is built)
# VAULT_SYNC_SECRET=
